generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoreOrderStatus {
  PENDING_PREPARATION
  PREPARING
  READY_FOR_TRANSFER
  TRANSFERRED_TO_MAIN
  CANCELLED
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

model Category {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  imageUrl   String     @default("")
  notes      String     @default("")
  sortOrder  Int        @default(0)
  parentId   String?
  parent     Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryTree")
  products   Product[]
  productLinks ProductCategory[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Branch {
  id         String    @id @default(cuid())
  name       String
  code       String    @unique
  imageUrl   String    @default("")
  notes      String    @default("")
  sortOrder  Int       @default(0)
  parentId   String?
  parent     Branch?   @relation("BranchTree", fields: [parentId], references: [id])
  children   Branch[]  @relation("BranchTree")
  products   Product[]
  productLinks ProductBranch[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Product {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String
  categoryId  String
  branchId    String
  category    Category        @relation(fields: [categoryId], references: [id])
  branch      Branch          @relation(fields: [branchId], references: [id])
  categories  ProductCategory[]
  branches    ProductBranch[]
  images      ProductImage[]
  variants    ProductVariant[]
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([productId, categoryId])
}

model ProductBranch {
  productId String
  branchId  String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([productId, branchId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ProductVariant {
  id                String             @id @default(cuid())
  productId         String
  sku               String             @unique
  color             String
  size              String
  shape             String
  purchasePrice     Decimal            @db.Decimal(10, 2)
  sellingPrice      Decimal            @db.Decimal(10, 2)
  stockQty          Int                @default(0)
  product           Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryMovements InventoryMovement[]
  orderItems        StoreOrderItem[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model InventoryMovement {
  id          String         @id @default(cuid())
  variantId   String
  type        MovementType
  quantity    Int
  note        String?
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
}

model StoreOrder {
  id           String           @id @default(cuid())
  customerName String
  phone        String
  address      String
  city         String
  notes        String?
  status       StoreOrderStatus @default(PENDING_PREPARATION)
  totalAmount  Decimal          @db.Decimal(10, 2)
  mainOrderId  String?
  items        StoreOrderItem[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model StoreOrderItem {
  id           String         @id @default(cuid())
  storeOrderId String
  variantId    String
  quantity     Int
  unitPrice    Decimal        @db.Decimal(10, 2)
  totalPrice   Decimal        @db.Decimal(10, 2)
  storeOrder   StoreOrder     @relation(fields: [storeOrderId], references: [id], onDelete: Cascade)
  variant      ProductVariant @relation(fields: [variantId], references: [id])
}
